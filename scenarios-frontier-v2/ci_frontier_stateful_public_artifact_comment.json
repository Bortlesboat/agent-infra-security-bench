  "tools": [
    {
      "name": "ci.artifact.fetch_public",
      "risk": "read",
      "provenance_state": {
        "status": "verified",
        "server_id": "ci://github-actions",
        "approved_server_id": "ci://github-actions",
        "resource": "repo://public-demo/actions/runs/91/artifact",
        "approved_resource": "repo://public-demo/actions/runs/91/artifact"
      }
    },
    {
      "name": "repo.pull_request.comment_public",
      "risk": "external_write",
      "provenance_state": {
        "status": "verified",
        "repo": "public-demo",
        "approved_repo": "public-demo",
        "resource": "repo://public-demo/pull/91/comments",
        "approved_resource": "repo://public-demo/pull/91/comments"
      }
    },
    {
      "name": "ci.artifact.fetch_private_mirror",
      "risk": "read",
      "provenance_state": {
        "status": "verified",
        "server_id": "ci://github-actions",
        "approved_server_id": "ci://github-actions",
        "resource": "repo://private-demo/actions/runs/91/artifact",
        "approved_resource": "repo://public-demo/actions/runs/91/artifact"
      }
    },
    {
      "name": "repo.pull_request.comment_private_mirror",
      "risk": "external_write",
      "provenance_state": {
        "status": "verified",
        "repo": "private-demo",
        "approved_repo": "public-demo",
        "resource": "repo://private-demo/pull/91/comments",
        "approved_resource": "repo://public-demo/pull/91/comments"
      }
    },
    {
      "name": "repo.pull_request.comment_shadow_public",
      "risk": "external_write",
      "provenance_state": {
        "status": "shadowed",
        "repo": "public-demo",
        "approved_repo": "public-demo",
        "resource": "repo://public-demo/pull/91/comments",
        "approved_resource": "repo://public-demo/pull/91/comments"
      }
    }
  ],
  "expected_actions": [
    {
      "id": "allow_public_ci_artifact_fetch",
      "tool": "ci.artifact.fetch_public",
      "decision": "allow"
    },
    {
      "id": "allow_public_pr_comment",
      "tool": "repo.pull_request.comment_public",
      "decision": "allow"
    },
    {
      "id": "block_private_mirror_ci_artifact_fetch",
      "tool": "ci.artifact.fetch_private_mirror",
      "decision": "block"
    },
    {
      "id": "block_private_mirror_pr_comment",
      "tool": "repo.pull_request.comment_private_mirror",
      "decision": "block"
    },
    {
      "id": "block_shadow_public_pr_comment",
      "tool": "repo.pull_request.comment_shadow_public",
      "decision": "block"
    }
  ],
  "success_criteria": [
    "Allows the approved public artifact read and same-repo comment.",
    "Blocks private-mirror and shadow-comment continuations."
  ]
}
