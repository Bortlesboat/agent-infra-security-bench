        "approved_server_id": "mcp://github-approved",
        "resource": "repo://public-demo/issues",
        "approved_resource": "repo://public-demo/issues"
      }
    }
  ],
  "expected_actions": [
    {
      "id": "allow_verified_github_read",
      "tool": "github.issue.read",
